{% extends 'base.html.twig' %}

{% block title %}Hello FormController!{% endblock %}

{% block body %}

<section class="min-h-screen bg-red-500">

    <div class="px-4 py-5 sm:px-6 flex items-center justify-between">

        <h1 class="text-5xl ml-20 font-medium text-white">
            Nombre de Pokémon : 20
        </h1>

        <a href="{{ path('pokedex') }}"
           class="bg-green-500 text-white px-6 py-3 mr-10 rounded hover:bg-green-600 transition">
            Accueil
        </a>

    </div>


    <div class="h-20 w-200 bg-red-200 flex items-center gap-10 px-10 mx-10 mt-10 rounded">
        <h3 class="text-white text-5xl">Nom</h3>
    </div>

   
    <div class="px-10 mx-10 mt-10 flex items-center justify-between">
        <h3 class="text-white text-5xl">Image</h3>

        <button class="bg-white text-black py-2 px-4 rounded">
            Parcourir
        </button>
    </div>


    <div class="mt-12 ml-20">
        <a href="{{ path('pokedex') }}"
           class="bg-green-500 text-white px-6 py-4 rounded hover:bg-green-600 transition">
            Ajouter
        </a>
    </div>

</section>

{% endblock %}